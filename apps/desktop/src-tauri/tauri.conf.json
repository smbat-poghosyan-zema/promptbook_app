{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Promptbook Runner",
  "version": "0.1.0",
  "identifier": "com.promptbook.runner",
  "build": {
    "beforeDevCommand": "pnpm --dir .. vite dev --port 1420",
    "beforeBuildCommand": "pnpm --dir .. vite build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Promptbook Runner",
        "width": 960,
        "height": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
